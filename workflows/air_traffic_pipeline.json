    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst total = items.length;\n\nconst avgAltitude =\n  items.reduce((s, i) => s + (i.json.altitude || 0), 0) / total;\n\nconst avgVelocity =\n  items.reduce((s, i) => s + (i.json.velocity || 0), 0) / total;\n\nreturn [{\n  json: {\n    total_aircraft: total,\n    avg_altitude: avgAltitude,\n    avg_velocity: avgVelocity\n  }\n}];"
      },

      "name": "Webhook",
      "webhookId": "1cc6857e-9de8-4f83-b736-ae3ba5b71f3d"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\n\nconst states = body.states || [];\nconst apiTime = body.time || Math.floor(Date.now() / 1000);\n\nif (!Array.isArray(states) || states.length === 0) {\n  return [{\n    json: {\n      valide: false,\n      type_erreur: \"NO_DATA\",\n      message: \"Aucune donnée avion reçue depuis OpenSky\",\n      source: \"opensky\",\n      date_traitement: new Date().toISOString()\n    }\n  }];\n}\n\n// On limite à 50 avions pour éviter de massacrer n8n/Postgres comme des sauvages\nconst limitedStates = states.slice(0, 50);\n\nreturn limitedStates.map((state) => {\n  const icao24 = state[0];\n  const callsign = state[1] ? String(state[1]).trim() : null;\n  const origin_country = state[2];\n  const longitude = state[5];\n  const latitude = state[6];\n  const altitude = state[7];\n  const velocity = state[9];\n\n  const errors = [];\n\n  if (!icao24) errors.push(\"icao24 manquant\");\n  if (longitude === null || latitude === null) errors.push(\"position manquante\");\n  if (typeof longitude === \"number\" && (longitude < -180 || longitude > 180)) errors.push(\"longitude invalide\");\n  if (typeof latitude === \"number\" && (latitude < -90 || latitude > 90)) errors.push(\"latitude invalide\");\n\n  const valide = errors.length === 0;\n\n  return {\n    json: {\n      icao24,\n      callsign,\n      origin_country,\n      longitude,\n      latitude,\n      altitude,\n      velocity,\n      timestamp_event: new Date(apiTime * 1000).toISOString(),\n      valide,\n      errors,\n      error_message: errors.join(\" | \"),\n      source: \"opensky\",\n      date_traitement: new Date().toISOString()\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
